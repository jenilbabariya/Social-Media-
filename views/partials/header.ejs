<!DOCTYPE html>
<html>

<head>
  <title><%= header.title || "Social Media App" %></title>

  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
   <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
   <link href="https://fonts.googleapis.com/css2?family=Grand+Hotel&display=swap" rel="stylesheet">
   <link rel="stylesheet" href="/css/style.css">
   <% if (header.css && header.css.length > 0) { %>
     <% header.css.forEach(function(stylesheet) { %>
       <link rel="stylesheet" href="/css/<%= stylesheet %>.css">
     <% }); %>
   <% } %>
</head>

<body class="<%= (typeof body !== 'undefined' && body.bodyClass) ? body.bodyClass : '' %>">

  <div class="container-fluid">
    <div class="row">

      <nav class="sidebar bg-white border-end vh-100 position-fixed">

        <div class="p-4 d-flex flex-column h-100">

          <h4 class="fw-bold text-center mb-5 brand" style="color: var(--bs-primary);">
            SocialMedia
          </h4>

          <ul class="nav flex-column flex-grow-1">


            <li class="nav-item mb-2">
              <a class="nav-link sidebar-link d-flex align-items-center <%= currentPath === '/dashboard' ? 'active' : '' %>" href="/dashboard">
                <i class="bi bi-house-door-fill me-3 fs-4"></i>
                <span>Home</span>
              </a>
            </li>

            <li class="nav-item mb-2">
              <a class="nav-link sidebar-link d-flex align-items-center <%= currentPath === '/search' ? 'active' : '' %>" href="/search">
                <i class="bi bi-search me-3 fs-4"></i>
                <span>Explore</span>
              </a>
            </li>

            <li class="nav-item mb-2">
              <a class="nav-link sidebar-link d-flex align-items-center <%= (currentPath.includes('/profile') || currentPath.includes('/connections')) ? 'active' : '' %>" href="/profile/<%= loggedInUser?.username %>">
                <i class="bi bi-person-circle me-3 fs-4"></i>
                <span>Profile</span>
              </a>
            </li>

            <li class="nav-item mb-2">
              <a class="nav-link sidebar-link d-flex align-items-center <%= currentPath === '/create-post' ? 'active' : '' %>" href="/create-post">
                <i class="bi bi-plus-square me-3 fs-4"></i>
                <span>Create Post</span>
              </a>
            </li>

            <li class="nav-item mb-2">
              <a class="nav-link sidebar-link d-flex align-items-center justify-content-between <%= currentPath === '/notifications' ? 'active' : '' %>" href="/notifications">
                <div class="d-flex align-items-center">
                  <i class="bi bi-heart me-3 fs-4"></i>
                  <span>Notifications</span>
                </div>
                <% if (typeof sidebarNotifCount !== 'undefined' && sidebarNotifCount > 0) { %>
                  <span class="sidebar-notif-badge ml-auto"><%= sidebarNotifCount %></span>
                <% } %>
              </a>
            </li>

            <li class="nav-item mb-2">
              <a class="nav-link sidebar-link d-flex align-items-center <%= (currentPath === '/settings' || currentPath === '/bookmarks') ? 'active' : '' %>" href="/settings">
                <i class="bi bi-gear me-3 fs-4"></i>
                <span>Settings</span>
              </a>
            </li>

          </ul>

          <div>
            <button type="button" id="logoutBtn" class="btn btn-outline-primary custom-logout w-100 rounded-pill">
              Logout
            </button>
          </div>

        </div>

      </nav>


      <main class="main-content <%= currentPath.startsWith('/profile') ? 'p-0' : 'px-4 py-4' %>">