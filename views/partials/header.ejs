<!DOCTYPE html>
<html>

<head>
  <title><%= header.title || "Social Media App" %></title>

  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
   <link rel="stylesheet" href="/css/style.css">
   <% if (header.css && header.css.length > 0) { %>
     <% header.css.forEach(function(stylesheet) { %>
       <link rel="stylesheet" href="/css/<%= stylesheet %>.css">
     <% }); %>
   <% } %>
</head>

<body class="<%= (typeof body !== 'undefined' && body.bodyClass) ? body.bodyClass : '' %>">

  <div class="container-fluid">
    <div class="row">

      <nav class="sidebar bg-white border-end vh-100 position-fixed">

        <div class="p-4 d-flex flex-column h-100">

          <h4 class="fw-bold text-center mb-5 brand">
            SocialMedia
          </h4>

          <ul class="nav flex-column flex-grow-1">

            <li class="nav-item mb-3">
              <a class="nav-link sidebar-link <%= currentPath === '/dashboard' ? 'active' : '' %>" href="/dashboard">
                Home
              </a>
            </li>

            <li class="nav-item mb-3">
              <a class="nav-link sidebar-link <%= currentPath === '/search' ? 'active' : '' %>" href="/search">
                Search
              </a>
            </li>

            <li class="nav-item mb-3">
              <a class="nav-link sidebar-link <%= (currentPath === '/profile/' + loggedInUser?.username || (typeof header !== 'undefined' && header.active === 'profile')) ? 'active' : '' %>" href="/profile/<%= loggedInUser?.username %>">
                Profile
              </a>
            </li>

            <li class="nav-item mb-3">
              <a class="nav-link sidebar-link <%= currentPath === '/create-post' ? 'active' : '' %>" href="/create-post">
                Create Post
              </a>
            </li>
            <li class="nav-item mb-3">
              <a class="nav-link sidebar-link d-flex align-items-center justify-content-between <%= currentPath === '/notifications' ? 'active' : '' %>" href="/notifications">
                <span>Notifications</span>
                <% if (typeof sidebarNotifCount !== 'undefined' && sidebarNotifCount > 0) { %>
                  <span class="sidebar-notif-badge"><%= sidebarNotifCount %></span>
                <% } %>
              </a>
            </li>

            <li class="nav-item mb-3">
              <a class="nav-link sidebar-link <%= (currentPath === '/settings' || currentPath === '/bookmarks') ? 'active' : '' %>" href="/settings">
                Settings
              </a>
            </li>

          </ul>

          <div>
            <button type="button" id="logoutBtn" class="btn btn-outline-primary custom-logout w-100 rounded-pill">
              Logout
            </button>
          </div>

        </div>

      </nav>


      <main class="main-content <%= currentPath.startsWith('/profile') ? 'p-0' : 'px-4 py-4' %>">