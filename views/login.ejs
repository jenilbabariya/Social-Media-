<!DOCTYPE html>
<html>
<head>
  <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">

  <div class="container min-vh-100 d-flex align-items-center justify-content-center">
    <div class="col-11 col-sm-8 col-md-5 col-lg-4">

      <div class="card custom-shadow p-4">
        
        <h3 class="text-center mb-10">Login</h3>

        <p id="error" class="text-danger text-center"></p>
        <p id="success" class="text-success text-center"></p>

        <form id="loginForm">

          <div class="mb-3">
            <input
              type="text"
              class="form-control"
              id="login"
              name="login"
              placeholder="Username or Email"
              autocomplete="username"
              required
            />
            <div class="invalid-feedback" id="loginError"></div>
          </div>

          <div class="mb-3">
            <input
              type="password"
              class="form-control"
              id="password"
              name="password"
              placeholder="Password"
              autocomplete="current-password"
              required
            />
            <div class="invalid-feedback" id="passwordError"></div>
          </div>

          <button type="submit" id="loginButton" class="btn btn-primary w-100 mb-3">
            Login
          </button>

          <div class="text-center">
            <a href="/forgot-password" class="small text-decoration-none">
              Forgot Password?
            </a>
          </div>

        </form>

      </div>

    </div>
  </div>

  <script src="/js/login.js"></script>

</body>
</html>