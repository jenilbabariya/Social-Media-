<!DOCTYPE html>
<html>
<head>
  <title>Forgot Password</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">

  <div class="container min-vh-100 d-flex align-items-center justify-content-center">
    <div class="col-11 col-sm-8 col-md-5 col-lg-4">

      <div class="card custom-shadow p-4">
        <p id="error" class="text-danger text-center"></p>
        <p id="success" class="text-success text-center"></p>

        <h3 class="text-center mb-3">Forgot Password</h3>

        <p class="text-muted text-center small mb-4">
          Enter your email and we’ll send you a reset link.
        </p>

        <form id="forgotForm" action="/api/auth/forgot-password" method="POST">

          <div class="mb-3">
            <input 
              type="email" 
              name="email" 
              id="email"
              class="form-control"
              placeholder="Enter your email"
              autocomplete="email"
              required 
            />
          </div>

          <button type="submit" class="btn btn-primary w-100 mb-3">
            Send Reset Link
          </button>

        </form>

        <div class="text-center">
          <a href="/login-page" class="small text-decoration-none">
            Back to Login
          </a>
        </div>

      </div>

    </div>
  </div>
<script src="js/forgot.js"></script>
</body>
</html>